# Database (Neon PostgreSQL) — rotate credentials after initial setup
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Payload CMS secret — generate with: openssl rand -base64 32
PAYLOAD_SECRET=your-32-char-secret-here

# Vercel Blob storage token
BLOB_READ_WRITE_TOKEN=

# Email (Resend)
RESEND_API_KEY=
ADMIN_EMAIL=info@metabox.mu

# App URL
NEXT_PUBLIC_SITE_URL=https://katana-website.vercel.app
